# Database (PostgreSQL). Use a local Postgres or e.g. Neon, Supabase.
DATABASE_URL=postgresql://user:password@localhost:5432/californiaweddingvenues

# NextAuth
NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://californiaweddingvenues.ca
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Stripe (use test keys for dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_STANDARD_MONTHLY=price_...
STRIPE_PRICE_STANDARD_ANNUAL=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...

# Optional: email (Resend recommended). If unset, lead emails are logged only.
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@californiaweddingvenues.xyz

# Optional: admin seed (email that can access /admin)
ADMIN_EMAIL=admin@example.com

# Photo uploads (Vercel Blob). Add in Vercel: Project → Storage → Blob → Create, then copy token.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Neon Auth (from Neon Console → Auth → Project Info)
NEON_AUTH_BASE_URL=https://ep-lively-morning-aigsatjs.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://ep-lively-morning-aigsatjs.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
# NEON_AUTH_COOKIE_SECRET=your-32-char-secret  # if using Neon Auth SDK for sessions
